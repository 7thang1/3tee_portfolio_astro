---
---
<section class="section section-alt" id="contact">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">// 06</span>
            <h2 class="section-title">Get In Touch</h2>
            <div class="section-line"></div>
        </div>
        <div class="contact-grid">
            <div class="contact-info">
                <h3 class="contact-heading">Let's connect!</h3>
                <p class="contact-text">Đang tìm kiếm cơ hội mới hoặc muốn trao đổi về infrastructure, DevOps, hay
                    SRE? Hãy liên hệ với mình!</p>
                <div class="contact-items">
                    <a href="mailto:tanthinhdev@gmail.com" class="contact-item">
                        <span class="contact-icon">📧</span>
                        <div>
                            <span class="contact-label">Email</span>
                            <span class="contact-value">tanthinhthi@gmail.com</span>
                        </div>
                    </a>
                    <a href="https://www.linkedin.com/in/tanthinhthi/" class="contact-item" target="_blank">
                        <span class="contact-icon">💼</span>
                        <div>
                            <span class="contact-label">LinkedIn</span>
                            <span class="contact-value">linkedin.com/in/tanthinhthi</span>
                        </div>
                    </a>
                    <a href="https://github.com/just3tee" class="contact-item" target="_blank">
                        <span class="contact-icon">🐙</span>
                        <div>
                            <span class="contact-label">GitHub</span>
                            <span class="contact-value">github.com/just3tee</span>
                        </div>
                    </a>
                    <a href="#" class="contact-item">
                        <span class="contact-icon">📍</span>
                        <div>
                            <span class="contact-label">Location</span>
                            <span class="contact-value">Ho Chi Minh City, Vietnam</span>
                        </div>
                    </a>
                </div>

                <!-- Status Widget -->
                <div class="status-widget">
                    <div class="status-header">
                        <span class="status-dot-live"></span>
                        <span>System Status</span>
                    </div>
                    <div class="status-bars">
                        <div class="status-bar-item">
                            <span>Available for hire</span>
                            <span class="status-active">● Active</span>
                        </div>
                        <div class="status-bar-item">
                            <span>Response time</span>
                            <span class="status-time">&lt; 24h</span>
                        </div>
                        <div class="status-bar-item">
                            <span>Remote / On-site</span>
                            <span class="status-active">● Both</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="contact-form-container">
                <form class="contact-form" id="contact-form">
                    <div class="form-group">
                        <label for="name" class="form-label">Name</label>
                        <input type="text" id="name" name="name" class="form-input" placeholder="Your name"
                            required>
                    </div>
                    <div class="form-group">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" id="email" name="email" class="form-input" placeholder="you@example.com"
                            required>
                    </div>
                    <div class="form-group">
                        <label for="subject" class="form-label">Subject</label>
                        <select id="subject" name="subject" class="form-input">
                            <option value="hiring">Hiring / Job Opportunity</option>
                            <option value="consulting">Consulting Request</option>
                            <option value="collaboration">Collaboration</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="message" class="form-label">Message</label>
                        <textarea id="message" name="message" class="form-input form-textarea"
                            placeholder="Your message..." rows="5" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-full" id="submit-btn">
                        <span class="btn-text">Send Message</span>
                        <span class="btn-icon">→</span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>
