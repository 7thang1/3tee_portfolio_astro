---
---
<section class="section section-alt" id="skills">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">// 02</span>
            <h2 class="section-title">Tech Stack</h2>
            <div class="section-line"></div>
        </div>
        <div class="skills-grid">
            <!-- Operating Systems -->
            <div class="skill-category" data-aos="fade-up">
                <div class="skill-category-header">
                    <span class="skill-icon">🐧</span>
                    <h3>Operating Systems</h3>
                </div>
                <div class="skill-items">
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #FCC624"></span>Linux (RHEL/Ubuntu/CentOS)</div>
                </div>
                <div class="skill-bar-container">
                    <div class="skill-bar-label">
                        <span>Proficiency</span>
                        <span>95%</span>
                    </div>
                    <div class="skill-bar">
                        <div class="skill-bar-fill" data-width="95"></div>
                    </div>
                </div>
            </div>

            <!-- Container & Orchestration -->
            <div class="skill-category" data-aos="fade-up" data-aos-delay="100">
                <div class="skill-category-header">
                    <span class="skill-icon">🐳</span>
                    <h3>Containers & Orchestration</h3>
                </div>
                <div class="skill-items">
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #2496ED"></span>Docker</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #326CE5"></span>Kubernetes</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #EF7B4D"></span>Helm</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #F04E98"></span>Istio</div>
                </div>
                <div class="skill-bar-container">
                    <div class="skill-bar-label">
                        <span>Proficiency</span>
                        <span>90%</span>
                    </div>
                    <div class="skill-bar">
                        <div class="skill-bar-fill" data-width="90"></div>
                    </div>
                </div>
            </div>

            <!-- Cloud Platforms -->
            <div class="skill-category" data-aos="fade-up" data-aos-delay="200">
                <div class="skill-category-header">
                    <span class="skill-icon">☁️</span>
                    <h3>Cloud Platforms</h3>
                </div>
                <div class="skill-items">
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #FF9900"></span>AWS</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #4285F4"></span>Google Cloud</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #0089D6"></span>Azure</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #1A1918"></span>DigitalOcean</div>
                </div>
                <div class="skill-bar-container">
                    <div class="skill-bar-label">
                        <span>Proficiency</span>
                        <span>88%</span>
                    </div>
                    <div class="skill-bar">
                        <div class="skill-bar-fill" data-width="88"></div>
                    </div>
                </div>
            </div>

            <!-- IaC & Automation -->
            <div class="skill-category" data-aos="fade-up" data-aos-delay="300">
                <div class="skill-category-header">
                    <span class="skill-icon">⚙️</span>
                    <h3>IaC & Automation</h3>
                </div>
                <div class="skill-items">
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #7B42BC"></span>Terraform</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #EE0000"></span>Ansible</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #8418EB"></span>Pulumi</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #1BAF8F"></span>Packer</div>
                </div>
                <div class="skill-bar-container">
                    <div class="skill-bar-label">
                        <span>Proficiency</span>
                        <span>92%</span>
                    </div>
                    <div class="skill-bar">
                        <div class="skill-bar-fill" data-width="92"></div>
                    </div>
                </div>
            </div>

            <!-- CI/CD -->
            <div class="skill-category" data-aos="fade-up" data-aos-delay="400">
                <div class="skill-category-header">
                    <span class="skill-icon">🚀</span>
                    <h3>CI/CD Pipeline</h3>
                </div>
                <div class="skill-items">
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #FC6D26"></span>GitLab CI</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #2088FF"></span>GitHub Actions</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #EF7B4D"></span>ArgoCD</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #D33833"></span>Jenkins</div>
                </div>
                <div class="skill-bar-container">
                    <div class="skill-bar-label">
                        <span>Proficiency</span>
                        <span>87%</span>
                    </div>
                    <div class="skill-bar">
                        <div class="skill-bar-fill" data-width="87"></div>
                    </div>
                </div>
            </div>

            <!-- Monitoring & Observability -->
            <div class="skill-category" data-aos="fade-up" data-aos-delay="500">
                <div class="skill-category-header">
                    <span class="skill-icon">📊</span>
                    <h3>Monitoring & Observability</h3>
                </div>
                <div class="skill-items">
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #E6522C"></span>Prometheus</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #F46800"></span>Grafana</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #005571"></span>ELK Stack</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #00ADD8"></span>Datadog</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #4AABEE"></span>PagerDuty</div>
                </div>
                <div class="skill-bar-container">
                    <div class="skill-bar-label">
                        <span>Proficiency</span>
                        <span>93%</span>
                    </div>
                    <div class="skill-bar">
                        <div class="skill-bar-fill" data-width="93"></div>
                    </div>
                </div>
            </div>

            <!-- Networking -->
            <div class="skill-category" data-aos="fade-up" data-aos-delay="600">
                <div class="skill-category-header">
                    <span class="skill-icon">🌐</span>
                    <h3>Networking & Security</h3>
                </div>
                <div class="skill-items">
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #009639"></span>Nginx / HAProxy</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #FF6C37"></span>Cloudflare</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #5B2D8E"></span>WireGuard / OpenVPN</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #333333"></span>iptables / nftables</div>
                </div>
                <div class="skill-bar-container">
                    <div class="skill-bar-label">
                        <span>Proficiency</span>
                        <span>85%</span>
                    </div>
                    <div class="skill-bar">
                        <div class="skill-bar-fill" data-width="85"></div>
                    </div>
                </div>
            </div>

            <!-- Scripting -->
            <div class="skill-category" data-aos="fade-up" data-aos-delay="700">
                <div class="skill-category-header">
                    <span class="skill-icon">💻</span>
                    <h3>Scripting & Programming</h3>
                </div>
                <div class="skill-items">
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #4EAA25"></span>Bash / Shell</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #3776AB"></span>Python</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #00ADD8"></span>Go</div>
                    <div class="skill-badge"><span class="skill-dot" style="--dot-color: #CB171E"></span>Ruby</div>
                </div>
                <div class="skill-bar-container">
                    <div class="skill-bar-label">
                        <span>Proficiency</span>
                        <span>82%</span>
                    </div>
                    <div class="skill-bar">
                        <div class="skill-bar-fill" data-width="82"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
