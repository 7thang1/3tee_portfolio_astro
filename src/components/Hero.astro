---
---
<section class="hero" id="hero">
    <div class="hero-content">
        <div class="terminal-window">
            <div class="terminal-header">
                <div class="terminal-dots">
                    <span class="dot dot-red"></span>
                    <span class="dot dot-yellow"></span>
                    <span class="dot dot-green"></span>
                </div>
                <div class="terminal-title">3tee@sre-portfolio:~</div>
            </div>
            <div class="terminal-body">
                <div class="terminal-line">
                    <span class="prompt">$</span>
                    <span class="command" id="typed-command"></span>
                    <span class="cursor-blink">▌</span>
                </div>
                <div class="terminal-output" id="terminal-output"></div>
            </div>
        </div>
        <div class="hero-info">
            <div class="hero-tag">System Administrator & Platform Engineer</div>
            <h1 class="hero-name">Thi Tan Thinh</h1>
            <p class="hero-description">System Administrator tại <span class="highlight">Sacombank</span>. Vận hành digital banking trên <span class="highlight">Red Hat OpenShift</span>, chuyên về <span class="highlight">Kubernetes</span>, <span class="highlight">Observability</span> và <span class="highlight">Cloud Infrastructure</span>.</p>
            <div class="hero-stats">
                <div class="stat-item">
                    <span class="stat-number" data-target="99.99">0</span><span class="stat-suffix">%</span>
                    <span class="stat-label">Uptime SLA</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number" data-target="3">0</span><span class="stat-suffix">+</span>
                    <span class="stat-label">Years Experience</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number" data-target="3">0</span><span class="stat-suffix"></span>
                    <span class="stat-label">Red Hat Certs</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number" data-target="2">0</span><span class="stat-suffix"></span>
                    <span class="stat-label">Banking Enterprises</span>
                </div>
            </div>
            <div class="hero-actions">
                <a href="#contact" class="btn btn-primary">
                    <span class="btn-icon">→</span> Liên hệ ngay
                </a>
                <a href="#projects" class="btn btn-secondary">
                    <span class="btn-icon">⚡</span> Xem Projects
                </a>
            </div>
        </div>
    </div>
    <div class="scroll-indicator">
        <div class="scroll-mouse">
            <div class="scroll-wheel"></div>
        </div>
        <span>Scroll Down</span>
    </div>
</section>
